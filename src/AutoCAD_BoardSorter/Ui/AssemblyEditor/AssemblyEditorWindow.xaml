<Window x:Class="AutoCAD_BoardSorter.Ui.AssemblyEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Конструктор сборок"
        Width="1320"
        Height="860"
        WindowStartupLocation="CenterScreen"
        Background="#0F172A"
        Foreground="#E2E8F0"
        PreviewKeyDown="OnWindowPreviewKeyDown"
        PreviewKeyUp="OnWindowPreviewKeyUp">
    <Window.Resources>
        <Style x:Key="ToolButtonStyle" TargetType="ToggleButton">
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="#2563EB"/>
                                <Setter Property="BorderBrush" Value="#60A5FA"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#60A5FA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PanelLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="PanelValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F8FAFC"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <Style x:Key="EditorTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#111827"/>
            <Setter Property="Foreground" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#111827"
                BorderBrush="#1F2937"
                BorderThickness="1"
                CornerRadius="10"
                Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="92"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="92"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Grid.Column="0">
                    <ToggleButton x:Name="SelectToolButton" Style="{StaticResource ToolButtonStyle}" Content="Выбор" Click="OnToolButtonClick"/>
                    <ToggleButton x:Name="VerticalToolButton" Style="{StaticResource ToolButtonStyle}" Content="Стойка" Click="OnToolButtonClick"/>
                    <ToggleButton x:Name="HorizontalToolButton" Style="{StaticResource ToolButtonStyle}" Content="Полка" Click="OnToolButtonClick"/>
                    <ToggleButton x:Name="FrontToolButton" Style="{StaticResource ToolButtonStyle}" Content="Передняя стенка" Click="OnToolButtonClick"/>
                    <ToggleButton x:Name="BackToolButton" Style="{StaticResource ToolButtonStyle}" Content="Задняя стенка" Click="OnToolButtonClick"/>
                    <ToggleButton x:Name="DrawersToolButton" Style="{StaticResource ToolButtonStyle}" Content="Ящики" Click="OnToolButtonClick"/>
                </StackPanel>

                <TextBlock Grid.Column="2" VerticalAlignment="Center" Foreground="#94A3B8" Text="Материал"/>
                <ComboBox x:Name="MaterialComboBox" Grid.Column="4" IsEditable="True" Margin="0,0,12,0" SelectionChanged="OnMaterialChanged" LostKeyboardFocus="OnMaterialComboLostFocus"/>
                <TextBlock Grid.Column="6" VerticalAlignment="Center" Foreground="#94A3B8" Text="Толщина"/>
                <TextBox x:Name="ThicknessTextBox" Grid.Column="8" Width="92" HorizontalAlignment="Left" Style="{StaticResource EditorTextBoxStyle}" TextChanged="OnThicknessChanged"/>
                <TextBlock Grid.Column="10" VerticalAlignment="Center" Foreground="#94A3B8" Text="Отступ"/>
                <TextBox x:Name="OffsetTextBox" Grid.Column="12" Width="92" HorizontalAlignment="Left" Style="{StaticResource EditorTextBoxStyle}" TextChanged="OnOffsetChanged"/>

                <Button x:Name="ReloadButton" Grid.Column="14" Padding="14,8" Margin="0,0,0,0" Click="OnReloadClick">Обновить</Button>
                <Button x:Name="CommitButton" Grid.Column="16" Padding="14,8" Click="OnCommitClick" Visibility="Collapsed" IsEnabled="False">Добавить в нишу</Button>
                <Button x:Name="UndoButton" Grid.Column="18" Padding="12,8" Click="OnUndoClick">Отменить</Button>
                <Button x:Name="RedoButton" Grid.Column="20" Padding="12,8" Click="OnRedoClick">Повторить</Button>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="#111827"
                    BorderBrush="#1F2937"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <TextBlock Foreground="#94A3B8" Text="Фронтальный вид" FontWeight="SemiBold"/>
                        <TextBlock x:Name="SceneSummaryTextBlock" Margin="14,0,0,0" Foreground="#64748B"/>
                        <Button x:Name="ResetViewButton" Margin="18,0,0,0" Padding="10,4" Click="OnResetViewClick">Сбросить вид</Button>
                    </StackPanel>

                    <Border Grid.Row="2"
                            Background="#0B1220"
                            BorderBrush="#233047"
                            BorderThickness="1"
                            CornerRadius="8"
                            ClipToBounds="True">
                        <Canvas x:Name="ViewportCanvas"
                                Background="#0B1220"
                                SizeChanged="OnViewportSizeChanged"
                                MouseMove="OnViewportMouseMove"
                                MouseLeave="OnViewportMouseLeave"
                                MouseLeftButtonDown="OnViewportMouseLeftButtonDown"
                                MouseLeftButtonUp="OnViewportMouseLeftButtonUp"
                                MouseWheel="OnViewportMouseWheel"
                                MouseRightButtonDown="OnViewportMouseRightButtonDown"
                                MouseRightButtonUp="OnViewportMouseRightButtonUp"/>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Background="#111827"
                    BorderBrush="#1F2937"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="16">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="#F8FAFC" Text="Свойства"/>

                        <TextBlock Style="{StaticResource PanelLabelStyle}" Margin="0,16,0,6" Text="Сборка"/>
                        <TextBlock x:Name="AssemblyNumberTextBlock" Style="{StaticResource PanelValueStyle}"/>

                        <TextBlock Style="{StaticResource PanelLabelStyle}" Text="Активная ниша"/>
                        <TextBlock x:Name="SelectedNicheTextBlock" Style="{StaticResource PanelValueStyle}"/>

                        <TextBlock Style="{StaticResource PanelLabelStyle}" Text="Preview"/>
                        <TextBlock x:Name="PreviewTextBlock" Style="{StaticResource PanelValueStyle}"/>

                        <Border x:Name="DrawerSettingsPanel"
                                Background="#0B1220"
                                BorderBrush="#334155"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="10"
                                Margin="0,0,0,12"
                                Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" Foreground="#F8FAFC" Text="Ящики" Margin="0,0,0,10"/>
                                <TextBlock Style="{StaticResource PanelLabelStyle}" Text="Количество"/>
                                <TextBox x:Name="DrawerCountTextBox" Style="{StaticResource EditorTextBoxStyle}" Margin="0,0,0,8" TextChanged="OnDrawerSettingsChanged"/>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <RadioButton x:Name="DrawerOverlayRadio" Content="Накладные" Foreground="#E2E8F0" Margin="0,0,14,0" Checked="OnDrawerModeChanged"/>
                                    <RadioButton x:Name="DrawerInsetRadio" Content="Вкладные" Foreground="#E2E8F0" Checked="OnDrawerModeChanged"/>
                                </StackPanel>

                                <UniformGrid Columns="2" Margin="0,0,0,8">
                                    <StackPanel Margin="0,0,6,6">
                                        <TextBlock Style="{StaticResource PanelLabelStyle}" Text="Слева"/>
                                        <TextBox x:Name="DrawerGapLeftTextBox" Style="{StaticResource EditorTextBoxStyle}" Margin="0" TextChanged="OnDrawerSettingsChanged"/>
                                    </StackPanel>
                                    <StackPanel Margin="6,0,0,6">
                                        <TextBlock Style="{StaticResource PanelLabelStyle}" Text="Справа"/>
                                        <TextBox x:Name="DrawerGapRightTextBox" Style="{StaticResource EditorTextBoxStyle}" Margin="0" TextChanged="OnDrawerSettingsChanged"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,6,6">
                                        <TextBlock Style="{StaticResource PanelLabelStyle}" Text="Сверху"/>
                                        <TextBox x:Name="DrawerGapTopTextBox" Style="{StaticResource EditorTextBoxStyle}" Margin="0" TextChanged="OnDrawerSettingsChanged"/>
                                    </StackPanel>
                                    <StackPanel Margin="6,0,0,6">
                                        <TextBlock Style="{StaticResource PanelLabelStyle}" Text="Снизу"/>
                                        <TextBox x:Name="DrawerGapBottomTextBox" Style="{StaticResource EditorTextBoxStyle}" Margin="0" TextChanged="OnDrawerSettingsChanged"/>
                                    </StackPanel>
                                </UniformGrid>

                                <TextBlock Style="{StaticResource PanelLabelStyle}" Text="Между ящиками"/>
                                <TextBox x:Name="DrawerGapBetweenTextBox" Style="{StaticResource EditorTextBoxStyle}" Margin="0,0,0,8" TextChanged="OnDrawerSettingsChanged"/>
                                <TextBlock Style="{StaticResource PanelLabelStyle}" Text="Отступ фасада (для вкладных)"/>
                                <TextBox x:Name="DrawerFrontGapTextBox" Style="{StaticResource EditorTextBoxStyle}" Margin="0,0,0,8" TextChanged="OnDrawerSettingsChanged"/>
                                <TextBlock Style="{StaticResource PanelLabelStyle}" Text="Толщина фасада"/>
                                <TextBox x:Name="DrawerFrontThicknessTextBox" Style="{StaticResource EditorTextBoxStyle}" Margin="0,0,0,8" TextChanged="OnDrawerSettingsChanged"/>
                                <TextBlock Style="{StaticResource PanelLabelStyle}" Text="Толщина дна"/>
                                <TextBox x:Name="DrawerBottomThicknessTextBox" Style="{StaticResource EditorTextBoxStyle}" Margin="0,0,0,8" TextChanged="OnDrawerSettingsChanged"/>

                                <CheckBox x:Name="DrawerAutoDepthCheckBox" Content="Глубина авто" Foreground="#E2E8F0" Margin="0,0,0,8" Checked="OnDrawerSettingsChanged" Unchecked="OnDrawerSettingsChanged"/>
                                <TextBox x:Name="DrawerDepthTextBox" Style="{StaticResource EditorTextBoxStyle}" Margin="0,0,0,8" TextChanged="OnDrawerSettingsChanged"/>

                                <TextBlock Style="{StaticResource PanelLabelStyle}" Text="Материалы"/>
                                <ComboBox x:Name="DrawerFrontMaterialComboBox" IsEditable="True" Margin="0,0,0,6" SelectionChanged="OnDrawerSettingsChanged" LostKeyboardFocus="OnDrawerComboLostFocus"/>
                                <ComboBox x:Name="DrawerBodyMaterialComboBox" IsEditable="True" Margin="0,0,0,6" SelectionChanged="OnDrawerSettingsChanged" LostKeyboardFocus="OnDrawerComboLostFocus"/>
                                <ComboBox x:Name="DrawerBottomMaterialComboBox" IsEditable="True" Margin="0,0,0,8" SelectionChanged="OnDrawerSettingsChanged" LostKeyboardFocus="OnDrawerComboLostFocus"/>

                                <TextBlock Style="{StaticResource PanelLabelStyle}" Text="Высоты фасадов"/>
                                <StackPanel x:Name="DrawerHeightsPanel"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Style="{StaticResource PanelLabelStyle}" Text="Распознанные панели"/>
                        <TextBlock x:Name="PanelSummaryTextBlock" Style="{StaticResource PanelValueStyle}"/>

                        <TextBlock Style="{StaticResource PanelLabelStyle}" Text="Предупреждения"/>
                        <ListBox x:Name="WarningsListBox"
                                 Background="#0B1220"
                                 Foreground="#F8FAFC"
                                 BorderBrush="#334155"
                                 BorderThickness="1"
                                 MinHeight="120"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="4"
                Background="#111827"
                BorderBrush="#1F2937"
                BorderThickness="1"
                CornerRadius="10"
                Padding="12">
            <TextBlock x:Name="StatusTextBlock"
                       Foreground="#CBD5E1"
                       TextWrapping="Wrap"/>
        </Border>
    </Grid>
</Window>
